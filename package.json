{
  "name": "Cebian",
  "description": "AI-powered browser extension for enhanced web browsing experience",
  "private": true,
  "version": "1.3.2",
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build && node scripts/scan-obfuscation.mjs .output/chrome-mv3",
    "build:firefox": "wxt build -b firefox && node scripts/scan-obfuscation.mjs .output/firefox-mv2",
    "zip": "wxt zip && node scripts/scan-obfuscation.mjs .output/chrome-mv3",
    "zip:firefox": "wxt zip -b firefox && node scripts/scan-obfuscation.mjs .output/firefox-mv2",
    "compile": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "check": "wxt prepare && tsc --noEmit && node scripts/lint-i18n.mjs && vitest run",
    "postinstall": "wxt prepare && simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm check"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.1",
    "@earendil-works/pi-agent-core": "^0.79.4",
    "@earendil-works/pi-ai": "^0.79.4",
    "@isomorphic-git/lightning-fs": "^4.6.2",
    "@lezer/highlight": "^1.2.3",
    "@mcp-ui/client": "^7.1.1",
    "@modelcontextprotocol/ext-apps": "^1.7.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "@wxt-dev/i18n": "^0.2.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "codemirror": "^6.0.2",
    "dexie": "^4.4.3",
    "fflate": "^0.8.3",
    "front-matter": "^4.0.2",
    "lucide-react": "^1.18.0",
    "pdfjs-dist": "^6.0.227",
    "picomatch": "^4.0.4",
    "radix-ui": "^1.5.0",
    "react": "^19.2.7",
    "react-arborist": "^3.10.4",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.17.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "tw-animate-css": "^1.4.0",
    "typebox": "^1.2.9"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.1",
    "@types/chrome": "^0.1.43",
    "@types/isomorphic-git__lightning-fs": "^4.4.8",
    "@types/picomatch": "^4.0.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "@webext-core/fake-browser": "^1.5.2",
    "@wxt-dev/module-react": "^1.1.5",
    "shadcn": "^4.11.0",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8",
    "wxt": "^0.20.26"
  }
}
