---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import ArticleSection from '../../../components/ArticleSection.astro';
import DocsFooter from '../../../components/DocsFooter.astro';
import { getDict, type Lang } from '../../../i18n';

export function getStaticPaths() {
  return [{ params: { lang: 'zh' } }, { params: { lang: 'en' } }];
}

const lang = Astro.params.lang as Lang;
const t = getDict(lang);
const d = t.docs.providers;
---
<BaseLayout lang={lang} title={d.title} description={d.lead} path="/docs/providers">
  <PageHeader eyebrow={d.eyebrow} title={d.title} lead={d.lead} />

  <article class="container-wide pb-24">
    <p class="text-[15.5px] leading-[1.75]" style="color: var(--fg);">{d.body}</p>

    <ArticleSection tag={d.categories_tag} title={d.categories_heading}>
      <div class="grid gap-3 sm:grid-cols-3">
        {d.categories.map((c) => (
          <div
            class="rounded-xl p-5 flex flex-col"
            style="border: 1px solid var(--border); background: var(--bg-elev);"
          >
            <div class="font-mono text-[12px] uppercase tracking-[0.16em]" style="color: var(--accent);">{c.name}</div>
            <h3 class="mt-2 h-minor leading-snug">{c.heading}</h3>
            <p class="mt-3 text-[13.5px] leading-relaxed flex-1" style="color: var(--fg-muted);">{c.body}</p>
          </div>
        ))}
      </div>
    </ArticleSection>

    <ArticleSection tag={d.notes_tag} title={d.notes_heading}>
      <ul class="space-y-2.5 text-[14px] leading-relaxed">
        {d.notes.map((n) => (
          <li class="relative pl-5">
            <span class="absolute left-0 top-[0.7em] h-[5px] w-[5px] rounded-full" style="background: var(--accent);" aria-hidden></span>
            {n}
          </li>
        ))}
      </ul>
    </ArticleSection>

    <DocsFooter lang={lang} slug="providers" />
  </article>
</BaseLayout>
