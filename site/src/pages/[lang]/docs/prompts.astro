---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import ArticleSection from '../../../components/ArticleSection.astro';
import CodeBlock from '../../../components/CodeBlock.astro';
import DocsFooter from '../../../components/DocsFooter.astro';
import { getDict, type Lang } from '../../../i18n';

export function getStaticPaths() {
  return [{ params: { lang: 'zh' } }, { params: { lang: 'en' } }];
}

const lang = Astro.params.lang as Lang;
const t = getDict(lang);
const d = t.docs.prompts;
---
<BaseLayout lang={lang} title={d.title} description={d.lead} path="/docs/prompts">
  <PageHeader eyebrow={d.eyebrow} title={d.title} lead={d.lead} />

  <article class="container-wide pb-24">
    <p class="text-[15.5px] leading-[1.75]" style="color: var(--fg);">{d.body}</p>

    <ArticleSection tag={d.variables_tag} title={d.variables_heading}>
      <div class="rounded-xl overflow-hidden" style="border: 1px solid var(--border); background: var(--bg-elev);">
        <table class="w-full text-[13.5px]">
          <tbody>
            {d.variables.map((v, i) => (
              <tr class={i > 0 ? 'border-t' : ''} style="border-color: var(--border);">
                <td class="px-4 py-3 font-mono whitespace-nowrap align-top" style="color: var(--accent);">{v.name}</td>
                <td class="px-4 py-3 align-top" style="color: var(--fg);">{v.desc}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </ArticleSection>

    <ArticleSection tag={d.example_tag} title={d.example_heading}>
      <p style="color: var(--fg-muted);">{d.example_body}</p>
      <div class="mt-5">
        <CodeBlock lang="yaml" code={d.example_code} />
      </div>
    </ArticleSection>

    <ArticleSection tag={d.panel_tag} title={d.panel_heading}>
      <p style="color: var(--fg-muted);">{d.panel_body}</p>
      <ul class="mt-5 space-y-2.5 text-[14px] leading-relaxed">
        {d.panel_bullets.map((b) => (
          <li class="relative pl-5">
            <span class="absolute left-0 top-[0.7em] h-[5px] w-[5px] rounded-full" style="background: var(--accent);" aria-hidden></span>
            {b}
          </li>
        ))}
      </ul>
    </ArticleSection>

    <DocsFooter lang={lang} slug="prompts" />
  </article>
</BaseLayout>
