---
import { getDict, LANGS, LOCALES, localePath, alternatePath, type Lang } from '../lib/i18n';

interface Props {
  lang: Lang;
  /** 无 locale 前缀的当前路径，用于语言切换映射 + 高亮当前项 */
  path: string;
}
const { lang, path } = Astro.props;
const t = getDict(lang);

const links = [
  { key: 'home', href: localePath(lang, '/'), label: t.nav.home, match: '/' },
  { key: 'docs', href: localePath(lang, '/docs'), label: t.nav.docs, match: '/docs' },
  { key: 'changelog', href: localePath(lang, '/changelog'), label: t.nav.changelog, match: '/changelog' },
  { key: 'github', href: 'https://github.com/maotoumao/Cebian', label: t.nav.github, match: '', external: true },
];

const isActive = (match: string) =>
  match === '/' ? path === '/' : !!match && (path === match || path.startsWith(match + '/'));
---
<header class="nav">
  <div class="wrap nav-inner">
    <a class="brand" href={localePath(lang, '/')}>
      <img src="/icon/128.png" alt="" width="24" height="24" />
      <span>Cebian</span>
    </a>

    <nav class="nav-links" aria-label={t.nav.menu}>
      {links.map((l) => (
        <a
          href={l.href}
          target={l.external ? '_blank' : undefined}
          rel={l.external ? 'noopener' : undefined}
          aria-current={!l.external && isActive(l.match) ? 'page' : undefined}
        >{l.label}</a>
      ))}
    </nav>

    <div class="nav-spacer"></div>

    <div class="nav-tools">
      <a class="nav-sponsor" href={localePath(lang, '/sponsor')} aria-label={t.nav.sponsor} aria-current={isActive('/sponsor') ? 'page' : undefined}>
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
        <span class="sponsor-label">{t.nav.sponsor}</span>
      </a>

      <button class="icon-btn" id="theme-toggle" type="button" aria-label={t.nav.theme}>
        <svg class="i-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
        <svg class="i-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
      </button>

      <div class="lang" data-open="false">
        <button class="lang-trigger" type="button" aria-expanded="false" aria-label={t.nav.language}>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 0 20M12 2a15.3 15.3 0 0 0 0 20"/></svg>
          <span class="lang-label">{LOCALES[lang].short}</span>
          <svg class="chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
        </button>
        <div class="lang-menu">
          {LANGS.map((l) => (
            <a
              href={alternatePath(path, l)}
              data-lang={l}
              hreflang={LOCALES[l].htmlLang}
              aria-current={l === lang ? 'true' : 'false'}
            >
              {LOCALES[l].name}
              <svg class="tick" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
            </a>
          ))}
        </div>
      </div>

      <button class="icon-btn nav-burger" id="nav-toggle" type="button" aria-label={t.nav.menu} aria-controls="nav-drawer" aria-expanded="false">
        <svg class="i-open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
        <svg class="i-close" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" aria-hidden="true"><path d="M6 6l12 12M18 6 6 18"/></svg>
      </button>
    </div>
  </div>

  <div class="nav-drawer" id="nav-drawer" hidden>
    <nav class="wrap" aria-label={t.nav.menu}>
      {links.map((l) => (
        <a
          href={l.href}
          target={l.external ? '_blank' : undefined}
          rel={l.external ? 'noopener' : undefined}
          aria-current={!l.external && isActive(l.match) ? 'page' : undefined}
        >{l.label}</a>
      ))}
    </nav>
  </div>
</header>

<style>
  .nav {
    position: sticky; top: 0; z-index: var(--z-sticky);
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    backdrop-filter: saturate(140%) blur(14px);
    border-bottom: 1px solid var(--line);
  }
  .nav-inner { display: flex; align-items: center; gap: 8px; height: 60px; }
  .brand { display: flex; align-items: center; gap: 10px; font-weight: 700; font-size: 17px; letter-spacing: -0.03em; }
  .brand img { width: 24px; height: 24px; border-radius: 6px; }
  .nav-links { display: flex; align-items: center; gap: 2px; margin-left: 18px; }
  .nav-links a { font-size: 14px; color: var(--ink-muted); padding: 8px 12px; border-radius: 8px; transition: color .15s, background .15s; }
  .nav-links a:hover { color: var(--ink); background: var(--surface-2); }
  .nav-links a[aria-current="page"] { color: var(--ink); }
  .nav-spacer { margin-left: auto; }
  .nav-tools { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }

  .icon-btn {
    width: 36px; height: 36px; display: grid; place-items: center;
    border: 1px solid var(--line-2); border-radius: 9px; background: var(--surface);
    color: var(--ink-muted); cursor: pointer;
    transition: color .15s, border-color .15s;
  }
  .icon-btn:hover { color: var(--ink); border-color: var(--ink-subtle); }
  .icon-btn svg { width: 16px; height: 16px; }
  .i-sun { display: none; }
  :global([data-theme="dark"]) .i-sun { display: block; }
  :global([data-theme="dark"]) .i-moon { display: none; }

  .nav-sponsor {
    display: inline-flex; align-items: center; gap: 7px; height: 36px;
    font-size: 14px; font-weight: 500; color: var(--accent); white-space: nowrap;
    padding: 0 13px; border: 1px solid var(--accent-line); border-radius: 9px;
    background: var(--accent-wash); transition: border-color .15s, background .15s;
  }
  .nav-sponsor:hover { border-color: var(--accent); background: color-mix(in srgb, var(--accent-wash) 70%, var(--accent-fill) 12%); }
  .nav-sponsor svg { width: 15px; height: 15px; transform-origin: center; }
  .nav-sponsor:hover svg { animation: heart-wiggle .6s var(--ease) both; }
  @keyframes heart-wiggle {
    0%, 100% { transform: scale(1) rotate(0); }
    20% { transform: scale(1.18) rotate(-9deg); }
    40% { transform: scale(1.08) rotate(8deg); }
    60% { transform: scale(1.14) rotate(-6deg); }
    80% { transform: scale(1.05) rotate(4deg); }
  }
  @media (prefers-reduced-motion: reduce) {
    .nav-sponsor:hover svg { animation: none; }
  }

  /* language dropdown */
  .lang { position: relative; }
  .lang-trigger {
    display: inline-flex; align-items: center; gap: 6px; height: 36px; padding: 0 10px;
    font-family: inherit; font-size: 13.5px; font-weight: 500; color: var(--ink-muted); white-space: nowrap;
    background: var(--surface); border: 1px solid var(--line-2); border-radius: 9px;
    cursor: pointer; transition: color .15s, border-color .15s;
  }
  .lang-trigger:hover { color: var(--ink); border-color: var(--ink-subtle); }
  .lang-trigger svg { width: 14px; height: 14px; }
  .chev { transition: transform .18s var(--ease); }
  .lang[data-open="true"] .chev { transform: rotate(180deg); }
  .lang-menu {
    position: absolute; top: calc(100% + 6px); right: 0; z-index: var(--z-dropdown);
    min-width: 156px; padding: 5px; background: var(--surface);
    border: 1px solid var(--line-2); border-radius: 11px; box-shadow: var(--shadow-lg);
    display: none; flex-direction: column; gap: 1px;
  }
  .lang[data-open="true"] .lang-menu { display: flex; }
  .lang-menu a {
    display: flex; align-items: center; justify-content: space-between; gap: 12px;
    font-size: 14px; color: var(--ink); padding: 9px 11px; border-radius: 7px;
    transition: background .12s;
  }
  .lang-menu a:hover { background: var(--surface-2); }
  .lang-menu .tick { width: 15px; height: 15px; color: var(--accent); opacity: 0; }
  .lang-menu a[aria-current="true"] { color: var(--accent); font-weight: 600; }
  .lang-menu a[aria-current="true"] .tick { opacity: 1; }

  /* mobile drawer */
  .nav-burger { display: none; }
  .nav-burger .i-close { display: none; }
  .nav-burger[aria-expanded="true"] .i-open { display: none; }
  .nav-burger[aria-expanded="true"] .i-close { display: block; }
  /* 抽屉桌面端完全不出现；窄屏默认收起（hidden 属性），点汉堡去掉 hidden 才展开。
     用 :not([hidden]) 控制，避免无条件 display:block 盖过 hidden 让抽屉常显。 */
  .nav-drawer { display: none; border-top: 1px solid var(--line); background: var(--bg); }
  .nav-drawer nav { display: flex; flex-direction: column; gap: 2px; padding-block: 12px 18px; }
  .nav-drawer a { font-size: 16px; color: var(--ink-muted); padding: 11px 4px; border-radius: 8px; }
  .nav-drawer a[aria-current="page"] { color: var(--ink); }

  @media (max-width: 820px) {
    .nav-links { display: none; }
    .nav-burger { display: grid; }
    .nav-drawer:not([hidden]) { display: block; }
    /* 移动端赞助按钮退化为纯图标，释放导航栏宽度 */
    .nav-sponsor { padding: 0; width: 36px; justify-content: center; }
    .sponsor-label { display: none; }
  }

  @media (max-width: 380px) {
    /* 极窄屏进一步隐藏语言标签文字，仅保留图标和箭头 */
    .lang-label { display: none; }
  }
</style>

<script>
  // 主题切换：写 localStorage，预绘制脚本下次读取。
  const themeBtn = document.getElementById('theme-toggle');
  themeBtn?.addEventListener('click', () => {
    const cur = document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
    const next = cur === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    try { localStorage.setItem('cebian-theme', next); } catch {}
  });

  // 语言切换：disclosure 开关 + 点外部关闭 + ESC 关闭并回焦触发器。
  const lang = document.querySelector('.lang');
  if (lang) {
    const trigger = lang.querySelector<HTMLButtonElement>('.lang-trigger');
    const setOpen = (open: boolean) => {
      lang.setAttribute('data-open', String(open));
      trigger?.setAttribute('aria-expanded', String(open));
    };
    trigger?.addEventListener('click', (e) => {
      e.stopPropagation();
      setOpen(lang.getAttribute('data-open') !== 'true');
    });
    // 记住用户显式选择的语言，供根路径 / 的协商脚本优先采用。
    lang.querySelectorAll<HTMLAnchorElement>('.lang-menu a').forEach((a) => {
      a.addEventListener('click', () => {
        try { localStorage.setItem('cebian-lang', a.dataset.lang || ''); } catch {}
      });
    });
    document.addEventListener('click', (e) => {
      if (!lang.contains(e.target as Node)) setOpen(false);
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && lang.getAttribute('data-open') === 'true') {
        setOpen(false);
        trigger?.focus();
      }
    });
  }

  // 移动端抽屉。图标由 CSS 按 aria-expanded 切换。
  const burger = document.getElementById('nav-toggle');
  const drawer = document.getElementById('nav-drawer');
  if (burger && drawer) {
    burger.addEventListener('click', () => {
      const willOpen = drawer.hasAttribute('hidden');
      if (willOpen) drawer.removeAttribute('hidden'); else drawer.setAttribute('hidden', '');
      burger.setAttribute('aria-expanded', String(willOpen));
    });
  }
</script>
