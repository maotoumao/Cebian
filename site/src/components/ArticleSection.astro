---
import Eyebrow from './Eyebrow.astro';
/**
 * Single-column long-form section. Sits inside `.container-wide` so the
 * eyebrow + heading line up with the page header, while body prose is
 * capped to a comfortable reading width.
 */
interface Props {
  id?: string;
  number?: string;
  tag?: string;
  title: string;
}
const { id, number, tag, title } = Astro.props;
---
<section id={id} class="mt-20 first:mt-0 scroll-mt-20">
  {tag && <Eyebrow number={number}>{tag}</Eyebrow>}
  <h2 class="h-major mt-3">{title}</h2>
  <div class="mt-5 max-w-3xl text-[15px] leading-[1.75]" style="color: var(--fg);">
    <slot />
  </div>
</section>
