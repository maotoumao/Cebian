---
interface Props {
  /** Placeholder caption displayed beneath the screenshot */
  caption: string;
  /**
   * Ratio like "16/10". Controls the aspect of the slot.
   * Use "9/16" for sidebar screenshots.
   */
  ratio?: string;
  /** If provided, renders as <img>; otherwise renders a placeholder block. */
  src?: string;
  alt?: string;
  /** Visual variant of the frame chrome */
  variant?: 'browser' | 'sidebar' | 'plain';
  placeholderLabel?: string;
}

const {
  caption,
  ratio = '16/10',
  src,
  alt = '',
  variant = 'browser',
  placeholderLabel = 'Screenshot placeholder',
} = Astro.props;
---
<figure class="group relative">
  <div
    class="overflow-hidden rounded-xl"
    style="border: 1px solid var(--border); background: var(--bg-elev); box-shadow: 0 30px 60px -30px rgba(0,0,0,0.35);"
  >
    {variant === 'browser' && (
      <div
        class="flex items-center gap-1.5 px-3 py-2 border-b"
        style="border-color: var(--border); background: color-mix(in oklab, var(--bg-elev) 88%, transparent);"
      >
        <span class="h-2.5 w-2.5 rounded-full" style="background:#ff5f57;"></span>
        <span class="h-2.5 w-2.5 rounded-full" style="background:#febc2e;"></span>
        <span class="h-2.5 w-2.5 rounded-full" style="background:#28c840;"></span>
        <div class="mx-auto text-[11px] font-mono" style="color: var(--fg-subtle);">cebian.catcat.work</div>
      </div>
    )}
    {variant === 'sidebar' && (
      <div
        class="flex items-center justify-between px-3 py-2 border-b"
        style="border-color: var(--border); background: color-mix(in oklab, var(--bg-elev) 88%, transparent);"
      >
        <div class="flex items-center gap-1.5">
          <img src="/icon/32.png" alt="" width="14" height="14" class="rounded-[3px]" />
          <span class="text-[11.5px] font-medium" style="color: var(--fg);">Cebian</span>
        </div>
        <div class="flex items-center gap-1 text-[11px]" style="color: var(--fg-subtle);">
          <span class="h-1.5 w-1.5 rounded-full pulse-dot" style="background: var(--accent);"></span>
          ready
        </div>
      </div>
    )}
    <div class="relative" style={`aspect-ratio: ${ratio};`}>
      {src ? (
        <img src={src} alt={alt} class="h-full w-full object-cover" loading="lazy" />
      ) : (
        <div class="absolute inset-0 flex items-center justify-center">
          <div
            class="absolute inset-0 bg-grid opacity-60"
            aria-hidden
          ></div>
          <div
            class="absolute inset-0"
            aria-hidden
            style="background: radial-gradient(ellipse at center, color-mix(in oklab, var(--accent-soft) 60%, transparent) 0%, transparent 60%);"
          ></div>
          <div class="relative flex flex-col items-center gap-2 text-center px-6">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" style="color: var(--fg-subtle);" aria-hidden>
              <rect x="3" y="4" width="18" height="14" rx="2" />
              <path d="M3 15l5-4 4 3 3-2 6 4" />
              <circle cx="9" cy="9" r="1.4" />
            </svg>
            <div class="text-[11px] font-mono tracking-wider uppercase" style="color: var(--fg-subtle);">
              {placeholderLabel}
            </div>
            <div class="text-[12.5px]" style="color: var(--fg-muted);">{caption}</div>
          </div>
        </div>
      )}
    </div>
  </div>
  {src && caption && (
    <figcaption class="mt-3 text-[12.5px] text-center" style="color: var(--fg-subtle);">{caption}</figcaption>
  )}
</figure>
